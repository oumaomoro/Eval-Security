PORT=3001
NODE_ENV=production

# Supabase Configuration
# Found at: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_from_api_settings

# OpenAI Configuration
# Found at: platform.openai.com -> API Keys
OPENAI_API_KEY=your_openai_api_key

# PayPal Configuration
# Found at: PayPal Developer Dashboard -> Apps & Credentials
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com # Use https://api-m.paypal.com for production

# Paystack Configuration
# Found at: Paystack Dashboard -> Settings -> API Keys & Webhooks
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# JWT Secret for Auth
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# Frontend URL (For CORS and webhooks)
FRONTEND_URL=https://app.cyberoptimize.io
VITE_API_URL=https://api.cyberoptimize.io # Required for frontend build environment

# File limits (in bytes)
MAX_FILE_SIZE=10485760
