PORT=3001
NODE_ENV=production

# Supabase Configuration
# Found at: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_from_api_settings

# OpenAI Configuration
# Found at: platform.openai.com -> API Keys
OPENAI_API_KEY=your_openai_api_key

# Resend Configuration
# Required for Inbound Pipeline Signature Verification
RESEND_WEBHOOK_SECRET=your_svix_secret_from_resend_dashboard

# PayPal Configuration
# Found at: PayPal Developer Dashboard -> Apps & Credentials
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com # Use https://api-m.paypal.com for production

# PayPal Subscription Plans (Derived from scripts/setup-paypal-plans.js)
PAYPAL_PLAN_STARTER_MONTH=plan_id_here
PAYPAL_PLAN_STARTER_YEAR=plan_id_here
PAYPAL_PLAN_PRO_MONTH=plan_id_here
PAYPAL_PLAN_PRO_YEAR=plan_id_here
PAYPAL_PLAN_ENTERPRISE_MONTH=plan_id_here
PAYPAL_PLAN_ENTERPRISE_YEAR=plan_id_here

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

STRIPE_PRICE_STARTER_MONTH=price_1...
STRIPE_PRICE_STARTER_YEAR=price_1...
STRIPE_PRICE_PRO_MONTH=price_1...
STRIPE_PRICE_PRO_YEAR=price_1...
STRIPE_PRICE_ENTERPRISE_MONTH=price_1...
STRIPE_PRICE_ENTERPRISE_YEAR=price_1...

# Paystack Configuration
# Found at: Paystack Dashboard -> Settings -> API Keys & Webhooks
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# JWT Secret for Auth
JWT_SECRET=costloci-secret-2026

# Frontend URL (For CORS and webhooks)
FRONTEND_URL=https://costloci.com
VITE_API_URL=https://api.costloci.com # Required for frontend build environment

# File limits (in bytes)
MAX_FILE_SIZE=10485760
