{
  "title": "CyberOptimize Enterprise Telemetry",
  "description": "Visibility into strategic feature usage, caching ROIs, and automated cron executions.",
  "widgets": [
    {
      "definition": {
        "title": "API Keys Processed / Hr",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:cyberoptimize.api.auth.success{*} by {host}.as_rate()",
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Redis Edge Cache Hits vs Misses",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:vercel.kv.cache.hit{*}",
            "style": { "palette": "dog_classic" }
          },
          {
            "q": "sum:vercel.kv.cache.miss{*}",
            "style": { "palette": "semantic" }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Usage Overages Recorded",
        "type": "query_value",
        "requests": [
          {
            "q": "sum:cyberoptimize.billing.overage.recorded.count{*}",
            "aggregator": "sum"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Stripe/PayPal Export Fee Webhooks",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:cyberoptimize.billing.webhook.success{*}"
          }
        ]
      }
    }
  ],
  "layout_type": "ordered"
}
