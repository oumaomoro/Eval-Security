# Costloci Enterprise Environment Configuration
# Template for Production Deployment

# 1. DATABASE CONFIGURATION (Drizzle & Supabase)
DATABASE_URL=postgresql://user:password@host:port/dbname
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# 2. SOVEREIGN INTELLIGENCE HUB (Multi-Provider Cascade)
OPENAI_API_KEY=sk-proj-...
DEEPSEEK_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HF_TOKEN=hf_...
HF_MODEL_ID=your-username/costloci-kdpa-llama3
LOCAL_AI_BASE_URL=http://127.0.0.1:11434/v1

# 3. AUTHENTICATION & SECURITY
SESSION_SECRET=your_long_random_session_secret
JWT_SECRET=your_jwt_signing_secret
CSRF_SECRET=your_long_random_csrf_secret
CRON_SECRET=your_long_random_cron_secret
ALLOWED_ORIGINS=https://costloci.com,https://www.costloci.com,http://localhost:3200
NODE_ENV=production

# 4. CROSS-PLATFORM INTEGRATION
FRONTEND_URL=https://costloci.com
API_URL=https://api.costloci.com
VITE_API_URL=https://api.costloci.com

# 5. ENTERPRISE INTEGRATIONS (SignNow & Email)
SIGNNOW_API_KEY=your_signnow_api_key
RESEND_API_KEY=re_...

# 6. PAYMENT GATEWAYS (Paystack & PayPal)
PAYSTACK_SECRET_KEY=sk_live_...
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_BASE_URL=https://api-m.paypal.com

# PayPal Plan IDs (Starter, Pro, Enterprise)
PAYPAL_PLAN_STARTER_MONTH=P-XXXX
PAYPAL_PLAN_STARTER_YEAR=P-XXXX
PAYPAL_PLAN_PRO_MONTH=P-XXXX
PAYPAL_PLAN_PRO_YEAR=P-XXXX
PAYPAL_PLAN_ENTERPRISE_MONTH=P-XXXX
PAYPAL_PLAN_ENTERPRISE_YEAR=P-XXXX

# 7. DEPLOYMENT & CI/CD
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=team_...
VERCEL_PROJECT_ID=prj_...

# 8. REGIONAL COMPLIANCE
DEFAULT_JURISDICTION=KDPA
REGULATORY_BODY_EMAILS=dpo@odpc.go.ke,admin@costloci.com
