# Costloci Enterprise Environment Configuration
# Template for Production Deployment

# 1. DATABASE CONFIGURATION (Drizzle ORM)
# Example: postgresql://user:password@localhost:5432/Costloci
DATABASE_URL=your_postgresql_connection_string

# 2. AI INTELLIGENCE HUB (OpenAI)
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# 3. AUTHENTICATION & SECURITY
SESSION_SECRET=your_long_random_session_secret
NODE_ENV=production

# 4. CROSS-PLATFORM INTEGRATION (Word Add-in)
# The URL where the frontend is hosted (e.g. https://Costloci.enterprise.com)
FRONTEND_URL=http://localhost:5173

# 5. REGIONAL COMPLIANCE (Optional Overrides)
DEFAULT_JURISDICTION=KDPA
REGULATORY_BODY_EMAILS=dpo@odpc.go.ke,admin@Costloci.com
