# Costloci Enterprise Environment Configuration
# Template for Production Deployment

# 1. DATABASE CONFIGURATION (Drizzle ORM)
DATABASE_URL=postgresql://user:password@host:port/dbname

# 2. AI INTELLIGENCE HUB (OpenAI)
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# 3. AUTHENTICATION & SECURITY
SESSION_SECRET=your_long_random_session_secret
JWT_SECRET=your_jwt_signing_secret
NODE_ENV=production

# 4. CROSS-PLATFORM INTEGRATION (Word Add-in)
FRONTEND_URL=https://costloci.com
VITE_API_URL=https://api.costloci.com

# 5. ENTERPRISE INTEGRATIONS (SignNow & AI)
SIGNNOW_API_KEY=your_signnow_api_key

# 6. PAYMENT GATEWAYS (PayPal & Stripe)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_BASE_URL=https://api-m.paypal.com

# PayPal Plan IDs (Starter, Pro, Enterprise)
PAYPAL_PLAN_STARTER_MONTH=P-XXXX
PAYPAL_PLAN_STARTER_YEAR=P-XXXX
PAYPAL_PLAN_PRO_MONTH=P-XXXX
PAYPAL_PLAN_PRO_YEAR=P-XXXX
PAYPAL_PLAN_ENTERPRISE_MONTH=P-XXXX
PAYPAL_PLAN_ENTERPRISE_YEAR=P-XXXX

# Stripe (Optional/Secondary)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# 7. DEPLOYMENT & CI/CD
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
VERCEL_TOKEN=your_vercel_token

# 8. REGIONAL COMPLIANCE
DEFAULT_JURISDICTION=KDPA
REGULATORY_BODY_EMAILS=dpo@odpc.go.ke,admin@costloci.com
